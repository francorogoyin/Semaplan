    },
    {
      "Tipo": "Click",
      "Selector": "#Habitos_Nuevo",
      "Cartel": "Guardamos el hábito. Desde ahora aparece en el panel y puede registrarse como cualquier otro."
    },
    {
      "Tipo": "Esperar",
      "Segundos": 3,
      "Cartel": "Hábitos combina rutina, medición y revisión histórica en una sola sección."
    },
    {
      "Tipo": "Click",
      "Selector": "#Habitos_Cerrar",
      "Cartel": "Cerramos Hábitos con los cambios guardados."
    }
  ]
}
