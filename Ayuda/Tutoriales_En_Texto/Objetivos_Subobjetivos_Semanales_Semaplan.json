    },
    {
      "Tipo": "Rellenar",
      "Selector": "#Horas_Semanales",
      "Texto": "2",
      "Cartel": "Las horas semanales indican cuánto tiempo se quiere reservar para este objetivo."
    },
    {
      "Tipo": "Click",
      "Selector": "#Crear_Objetivo",
      "Cartel": "Guardamos el objetivo nuevo. Si se crea un objetivo real, queda guardado en la semana."
    },
    {
      "Tipo": "Esperar",
      "Segundos": 2,
      "Cartel": "Ahora vamos a seleccionar un objetivo con subobjetivos ya cargados para ver el seguimiento interno."
    },
    {
      "Tipo": "Click",
      "Selector": ".Emoji_Item[data-objetivo-id=\"Tutorial_Obj_Propuesta\"]",
      "Cartel": "Seleccionamos Preparar propuesta comercial desde la lista lateral."
    },
    {
      "Tipo": "Esperar_Selector",
      "Selector": "#Resumen_Objetivo"
    },
    {
      "Tipo": "Evaluar",
      "Codigo_Lineas": [
        "() => {",
        "  const Obj = Objetivo_Por_Id('Tutorial_Obj_Propuesta');",
        "  const Clave = Clave_Semana_Actual();",
        "  if (Obj) {",
        "    Obj.Subobjetivos_Contraidas_Semanales =",
        "      Obj.Subobjetivos_Contraidas_Semanales || {};",
        "    Obj.Subobjetivos_Contraidas_Semanales[Clave] = false;",
        "  }",
        "  if (typeof Render_Resumen_Objetivo === \"function\") {",
        "    Render_Resumen_Objetivo();",
        "  }",
        "}"
      ],
      "Cartel": "Expandimos los subobjetivos para ver los pasos internos del objetivo seleccionado."
    },
    {
      "Tipo": "Hover",
      "Selector": "#Resumen_Objetivo",
      "Cartel": "El resumen muestra el objetivo seleccionado, sus horas, sus bloques y sus subobjetivos de la semana."
    },
    {
      "Tipo": "Hover",
      "Selector": ".Subobjetivo_Item[data-subobjetivo-id=\"Tutorial_Sub_Presupuesto\"]",
      "Cartel": "Los subobjetivos son pasos internos. Ayudan a saber qué falta sin crear un objetivo separado."
    },
    {
      "Tipo": "Click",
      "Selector": ".Subobjetivo_Item[data-subobjetivo-id=\"Tutorial_Sub_Presupuesto\"] .Subobjetivo_Check",
      "Cartel": "Marcamos Revisar presupuesto como realizado. El avance queda guardado dentro del objetivo semanal."
    },
    {
      "Tipo": "Esperar",
      "Segundos": 3,
      "Cartel": "Esta combinación permite trabajar con un objetivo grande sin perder de vista los pasos chicos."
    }
  ]
