  ],
  "Acciones": [
    {
      "Tipo": "Ir_A",
      "Url": "https://semaplan.com"
    },
    {
      "Tipo": "Esperar_Funcion",
      "Codigo_Lineas": [
        "() => {",
        "  const Loader = document.getElementById('App_Loader');",
        "  const Auth = document.getElementById('Auth_Overlay');",
        "  return !!document.getElementById('Tareas_Boton') &&",
        "    Loader?.classList.contains('Oculto') &&",
        "    !Auth?.classList.contains('Activo');",
        "}"
      ]
    },
    {
      "Tipo": "Evaluar",
      "Codigo_Lineas": [
        "async () => {",
        "  Config.Menu_Estilo = 'Iconos';",
        "  if (typeof Plan_Modal_Modo !== \"undefined\") {",
        "    Plan_Modal_Modo = 'Periodos';",
        "  }",
        "  if (typeof Aplicar_Estilo_Menu === \"function\") {",
        "    Aplicar_Estilo_Menu();",
        "  }",
        "  if (typeof Cerrar_Tareas === \"function\") Cerrar_Tareas();",
        "  if (typeof Cerrar_Modal_Habitos === \"function\") {",
        "    Cerrar_Modal_Habitos(true);",
        "  }",
        "  if (typeof Cerrar_Plan === \"function\") Cerrar_Plan();",
        "  if (typeof Cerrar_Resumen_Semanal === \"function\") {",
        "    Cerrar_Resumen_Semanal();",
        "  }",
        "  if (typeof Cerrar_Focus_Mode === \"function\") {",
        "    Cerrar_Focus_Mode();",
        "  }",
        "}"
      ]
    },
    {
      "Tipo": "Esperar",
      "Segundos": 13,
      "Duracion_Cartel_Segundos": 13,
      "Tipo_Cartel": "Intro",
      "Cartel": "En este video vamos a recorrer Objetivos y subobjetivos semanales. Sirven para decidir qué importa esta semana y dividirlo en pasos concretos que se puedan marcar.",
      "Posicion": "Inferior"
    },
    {
      "Tipo": "Hover",
