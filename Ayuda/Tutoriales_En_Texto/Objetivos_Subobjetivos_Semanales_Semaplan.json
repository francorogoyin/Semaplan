    },
    {
      "Tipo": "Esperar_Selector",
      "Selector": "#Nombre_Objetivo"
    },
    {
      "Tipo": "Rellenar",
      "Selector": "#Nombre_Objetivo",
      "Texto": "Ordenar papeles del estudio",
      "Cartel": "El nombre debe ser concreto y reconocible."
    },
    {
      "Tipo": "Rellenar",
      "Selector": "#Descripcion_Corta_Objetivo",
      "Texto": "Separar facturas, contratos y notas sueltas.",
