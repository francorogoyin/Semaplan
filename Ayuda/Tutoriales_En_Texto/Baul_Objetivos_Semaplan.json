    },
    {
      "Tipo": "Esperar_Funcion",
      "Codigo_Lineas": [
        "() => {",
        "  const Loader = document.getElementById('App_Loader');",
        "  const Auth = document.getElementById('Auth_Overlay');",
        "  return !!document.getElementById('Baul_Boton') &&",
        "    Loader?.classList.contains('Oculto') &&",
        "    !Auth?.classList.contains('Activo');",
        "}"
      ]
    },
    {
      "Tipo": "Evaluar",
      "Codigo_Lineas": [
        "async () => {",
        "  const Normalizar = (Texto) => (Texto || '')",
        "    .toString()",
        "    .normalize('NFD')",
        "    .replace(/[\\u0300-\\u036f]/g, '')",
        "    .toLowerCase()",
        "    .replace(/\\s+/g, ' ')",
        "    .trim();",
        "  const Fecha = (Dias) => {",
        "    const Valor = new Date();",
        "    Valor.setDate(Valor.getDate() + Dias);",
        "    const Parte = (Numero) => String(Numero).padStart(2, '0');",
        "    return Valor.getFullYear() + '-' +",
        "      Parte(Valor.getMonth() + 1) + '-' +",
        "      Parte(Valor.getDate());",
        "  };",
        "  const Asegurar_Categoria = (Id, Nombre, Emoji, Color, Metas) => {",
        "    let Cat = Categorias.find((Item) => Item.Id === Id);",
        "    if (!Cat) {",
        "      Cat = { Id, Nombre, Emoji, Color_Baul: Color, Metadatos: [] };",
        "      Categorias.push(Cat);",
        "    }",
        "    Cat.Nombre = Nombre;",
        "    Cat.Emoji = Emoji;",
        "    Cat.Color_Baul = Color;",
        "    Cat.Metadatos = Array.isArray(Cat.Metadatos)",
        "      ? Cat.Metadatos : [];",
        "    Metas.forEach((Meta, Indice) => {",
        "      const Meta_Id = `${Id}_Meta_${Indice + 1}`;",
        "      let Actual = Cat.Metadatos.find((Item) =>",
        "        Item.Id === Meta_Id || Normalizar(Item.Nombre) === Normalizar(Meta)",
        "      );",
        "      if (!Actual) {",
        "        Actual = { Id: Meta_Id, Nombre: Meta };",
        "        Cat.Metadatos.push(Actual);",
        "      }",
        "      Actual.Id = Meta_Id;",
        "      Actual.Nombre = Meta;",
        "    });",
        "    return Cat;",
        "  };",
        "  const Asegurar_Etiqueta = (Id, Nombre) => {",
        "    let Tag = Etiquetas.find((Item) => Item.Id === Id);",
        "    if (!Tag) {",
        "      Tag = { Id, Nombre };",
        "      Etiquetas.push(Tag);",
        "    }",
        "    Tag.Nombre = Nombre;",
        "    return Tag;",
        "  };",
        "  const Lecturas = Asegurar_Categoria(",
        "    'Tutorial_Baul_Cat_Lecturas',",
        "    'Lecturas pendientes',",
        "    '\\ud83d\\udcda',",
        "    '#6f91d8',",
        "    ['Autor', 'Formato']",
        "  );",
        "  const Trabajo = Asegurar_Categoria(",
        "    'Tutorial_Baul_Cat_Trabajo',",
        "    'Trabajo y clientes',",
        "    '\\ud83d\\udcbc',",
        "    '#5f9c8d',",
        "    ['Cliente', 'Entregable']",
        "  );",
        "  const Casa_Salud = Asegurar_Categoria(",
        "    'Tutorial_Baul_Cat_Casa_Salud',",
        "    'Casa y salud',",
        "    '\\ud83e\\ude7a',",
        "    '#d47f64',",
        "    ['Lugar', 'Contacto']",
        "  );",
        "  const Viajes = Asegurar_Categoria(",
        "    'Tutorial_Baul_Cat_Viajes',",
        "    'Viajes e ideas',",
        "    '\\ud83e\\uddf3',",
        "    '#c08ad3',",
        "    ['Lugar', 'Temporada']",
        "  );",
        "  const Aprendizaje = Asegurar_Categoria(",
        "    'Tutorial_Baul_Cat_Aprendizaje',",
        "    'Aprendizaje',",
        "    '\\ud83c\\udf93',",
        "    '#b79b4f',",
        "    ['Fuente', 'Costo']",
        "  );",
        "  const Tags = {",
        "    Proxima: Asegurar_Etiqueta('Tutorial_Baul_Tag_Proxima', 'Proxima'),",
        "    Cliente: Asegurar_Etiqueta('Tutorial_Baul_Tag_Cliente', 'Cliente'),",
        "    Familia: Asegurar_Etiqueta('Tutorial_Baul_Tag_Familia', 'Familia'),",
        "    Comprar: Asegurar_Etiqueta('Tutorial_Baul_Tag_Comprar', 'Comprar'),",
        "    Curso: Asegurar_Etiqueta('Tutorial_Baul_Tag_Curso', 'Curso'),",
        "    Salud: Asegurar_Etiqueta('Tutorial_Baul_Tag_Salud', 'Salud'),",
        "    Archivada: Asegurar_Etiqueta('Tutorial_Baul_Tag_Archivada', 'Archivada')",
        "  };",
        "  const Nombres_Ejemplo = [",
        "    'Leer Los cuatro acuerdos',",
        "    'Preparar propuesta para cliente Norte',",
        "    'Comprar regalo de cumpleanos para Vero',",
        "    'Planificar escapada a Tandil',",
        "    'Revisar curso de fotografia',",
        "    'Cambiar filtros del aire acondicionado',",
        "    'Investigar seguro para notebook',",
        "    'Agendar chequeo medico anual'",
        "  ];",
        "  Baul_Objetivos = Baul_Objetivos.filter((Objetivo) => {",
        "    const Nombre = (Objetivo?.Nombre || '').toString();",
        "    if (/^Baul diag/i.test(Nombre)) return false;",
        "    return !Nombres_Ejemplo.includes(Nombre);",
        "  });",
        "  const Crear_Item = (Datos) => {",
        "    const Metadatos = {};",
        "    Object.entries(Datos.Metadatos || {}).forEach(([Nombre, Valor]) => {",
        "      const Meta = Datos.Categoria.Metadatos.find((Item) =>",
        "        Normalizar(Item.Nombre) === Normalizar(Nombre)",
        "      );",
        "      if (Meta) Metadatos[Meta.Id] = Valor;",
        "    });",
        "    const Item = Normalizar_Baul_Objetivo({",
        "      Nombre: Datos.Nombre,",
        "      Emoji: Datos.Emoji,",
        "      Es_Bolsa: Boolean(Datos.Es_Bolsa),",
        "      Categoria_Id: Datos.Categoria.Id,",
        "      Etiquetas_Ids: Datos.Etiquetas.map((Tag) => Tag.Id),",
        "      Metadatos,",
        "      Estado: Datos.Estado || 'Activa',",
        "      Archivada: Boolean(Datos.Archivada),",
        "      Color_Baul: Datos.Color || '',",
        "      Descripcion: Datos.Descripcion || '',",
        "      Horas_Aprox: Datos.Horas || 0,",
        "      Timeline: Datos.Timeline || null,",
        "      Orden_Personalizado: Preparar_Orden_Nueva_Objetivo_Baul()",
        "    });",
        "    if (Item) Baul_Objetivos.push(Item);",
        "  };",
        "  Crear_Item({",
        "    Nombre: 'Leer Los cuatro acuerdos',",
        "    Emoji: '\\ud83d\\udcda',",
        "    Categoria: Lecturas,",
        "    Etiquetas: [Tags.Proxima],",
        "    Metadatos: { Autor: 'Don Miguel Ruiz', Formato: 'Libro' },",
        "    Horas: 4,",
        "    Timeline: Fecha(10),",
        "    Descripcion: 'Leer y anotar ideas para conversar el domingo.'",
        "  });",
        "  Crear_Item({",
        "    Nombre: 'Preparar propuesta para cliente Norte',",
        "    Emoji: '\\ud83d\\udcbc',",
        "    Categoria: Trabajo,",
        "    Etiquetas: [Tags.Cliente, Tags.Proxima],",
        "    Metadatos: { Cliente: 'Norte SRL', Entregable: 'PDF' },",
        "    Horas: 3.5,",
        "    Timeline: Fecha(5),",
        "    Descripcion: 'Cerrar alcance, precio y proximos pasos.'",
        "  });",
        "  Crear_Item({",
        "    Nombre: 'Comprar regalo de cumpleanos para Vero',",
        "    Emoji: '\\ud83c\\udf81',",
        "    Categoria: Casa_Salud,",
        "    Etiquetas: [Tags.Familia, Tags.Comprar],",
        "    Metadatos: { Lugar: 'Centro', Contacto: 'Libreria Ateneo' },",
        "    Horas: 1.5,",
        "    Timeline: Fecha(2),",
        "    Descripcion: 'Mirar agenda, presupuesto y opciones de regalo.'",
        "  });",
        "  Crear_Item({",
        "    Nombre: 'Planificar escapada a Tandil',",
        "    Emoji: '\\ud83e\\uddf3',",
        "    Categoria: Viajes,",
        "    Etiquetas: [Tags.Familia],",
        "    Metadatos: { Lugar: 'Tandil', Temporada: 'Invierno' },",
        "    Horas: 2,",
        "    Timeline: Fecha(30),",
        "    Descripcion: 'Comparar alojamiento, traslado y fechas posibles.'",
        "  });",
        "  Crear_Item({",
        "    Nombre: 'Revisar curso de fotografia',",
        "    Emoji: '\\ud83d\\udcf7',",
        "    Categoria: Aprendizaje,",
        "    Etiquetas: [Tags.Curso],",
        "    Metadatos: { Fuente: 'Domestika', Costo: '$ 18.000' },",
        "    Estado: 'Postergada',",
        "    Horas: 2,",
        "    Timeline: Fecha(14),",
        "    Descripcion: 'Ver programa, fechas y trabajos finales.'",
        "  });",
        "  Crear_Item({",
        "    Nombre: 'Cambiar filtros del aire acondicionado',",
        "    Emoji: '\\ud83d\\udee0\\ufe0f',",
        "    Categoria: Casa_Salud,",
        "    Etiquetas: [Tags.Comprar],",
        "    Metadatos: { Lugar: 'Casa', Contacto: 'Ferreteria' },",
        "    Horas: 1,",
        "    Timeline: Fecha(7),",
        "    Descripcion: 'Comprar filtros y limpiar antes del frio fuerte.'",
        "  });",
        "  Crear_Item({",
        "    Nombre: 'Investigar seguro para notebook',",
        "    Emoji: '\\ud83d\\udee1\\ufe0f',",
        "    Categoria: Trabajo,",
        "    Etiquetas: [Tags.Archivada],",
        "    Metadatos: { Cliente: 'Uso personal', Entregable: 'Comparativo' },",
        "    Estado: 'Realizada',",
        "    Archivada: true,",
        "    Horas: 1,",
        "    Timeline: Fecha(-8),",
        "    Descripcion: 'Queda archivado como ejemplo ya revisado.'",
        "  });",
        "  Reindexar_Orden_Baul();",
        "  Config.Menu_Estilo = 'Iconos';",
        "  Config.Baul_Vista_Modo = 'Biblioteca';",
        "  Config.Baul_Ordenar_Por = 'Personalizado';",
        "  Config.Baul_Agrupar_Por = 'Ninguno';",
        "  Config.Baul_Mostrar_Archivadas = false;",
        "  Config.Baul_Objetivos_Por_Fila = 5;",
        "  if (typeof Aplicar_Estilo_Menu === 'function') {",
        "    Aplicar_Estilo_Menu();",
        "  }",
        "  Guardar_Estado();",
        "  if (typeof Forzar_Sync_Inmediato_Cambio_Critico === 'function') {",
        "    await Forzar_Sync_Inmediato_Cambio_Critico();",
        "  }",
        "}"
      ]
    }
  ],
