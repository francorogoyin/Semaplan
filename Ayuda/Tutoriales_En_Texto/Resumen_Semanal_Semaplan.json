    },
    {
      "Tipo": "Esperar",
      "Segundos": 2,
      "Cartel": "Esta lectura ayuda a detectar días cargados, días vacíos y distribución del trabajo."
    },
    {
      "Tipo": "Click",
      "Selector": ".Resumen_Sem_Tab:nth-child(3)",
