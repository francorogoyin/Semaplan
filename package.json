{
  "name": "semaplan",
  "version": "1.0.0",
  "description": "Aplicación web de planificación semanal con calendario,\r bolsa de horas, subtareas, patrones, abordajes y resumen\r semanal. Backend en Supabase: registro, login, datos\r sincronizados en la nube y accesibles desde cualquier\r dispositivo.",
  "main": "Desktop/Main_Process.js",
  "scripts": {
    "auth:semaplan": "node scripts/save-semaplan-auth.js",
    "desktop": "electron .",
    "desktop:build":
      "electron-builder --config Desktop/Builder_Config.json --win portable",
    "desktop:dist":
      "electron-builder --config Desktop/Builder_Config.json --dir",
    "desktop:icon":
      "powershell -ExecutionPolicy Bypass -File Desktop/Generar_Icono.ps1",
    "test": "playwright test",
    "test:e2e": "playwright test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
