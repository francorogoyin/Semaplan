{
  "appId": "com.semaplan.desktop",
  "productName": "Semaplan",
  "asar": true,
  "directories": {
    "output": "Aplicaciones/Desktop/Dist_Desktop"
  },
  "files": [
    "index.html",
    "Semaplan.html",
    "Aplicaciones/Desktop/**/*",
    "!Aplicaciones/Desktop/Dist_Desktop{,/**/*}",
    "package.json"
  ],
  "win": {
    "icon": "Aplicaciones/Desktop/Semaplan.ico",
    "target": [
      "portable"
    ],
    "artifactName":
      "Semaplan-Desktop-${version}.${ext}"
  }
}
